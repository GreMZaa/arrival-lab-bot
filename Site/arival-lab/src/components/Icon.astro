---
import { lucidePaths, type IconName } from '../lib/lucide-icons';

interface Props {
  name: IconName;
  size?: number;
  strokeWidth?: number;
  class?: string;
  ariaHidden?: boolean;
}

const {
  name,
  size = 20,
  strokeWidth = 2,
  class: className = '',
  ariaHidden = true,
} = Astro.props;

const paths = lucidePaths[name];
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden={ariaHidden ? 'true' : undefined}
  set:html={paths}
/>

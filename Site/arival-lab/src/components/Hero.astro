---
import Icon from './Icon.astro';
---
<section class="section hero-section">
  <div class="aurora-glow glow-1"></div>
  <div class="aurora-glow glow-2"></div>
  <div class="aurora-glow glow-3"></div>

  <div class="container hero-container">
    <div class="hero-content" data-reveal>
      <div class="eyebrow eyebrow-margin">Лаборатория виртуального стриминга</div>
      <h1 class="display hero-headline">
        Создайте своё цифровое <span class="gradient-text">альтер-эго</span>
      </h1>
      <p class="hero-lead">
        Запускаем VTuber-карьеры под ключ. Помогаем подобрать образ, настраиваем оборудование для трекинга лица и тела, выводим на специализированные площадки и берём на продюсирование.
      </p>
      <div class="hero-actions-container">
        <a href="https://t.me/ArrivalLabBOT?start=website" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-large animate-glow">
          <Icon name="rocket" size={20} />
          <span>Начать подбор</span>
          <Icon name="arrow-right" size={18} class="btn-arrow" />
        </a>
        <a href="#programs" class="btn btn-ghost btn-large">
          <span>Наши программы</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding-block-start: calc(var(--header-h) + var(--space-10));
    padding-block-end: var(--space-10);
    overflow: hidden;
    min-height: 75vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .hero-container {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .hero-content {
    max-width: 820px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .eyebrow-margin {
    margin-bottom: var(--space-4);
  }

  .hero-headline {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.15;
    margin-bottom: var(--space-4);
    letter-spacing: -0.03em;
    font-weight: 800;
  }

  .hero-lead {
    font-size: var(--fs-lg);
    color: var(--color-text-soft);
    margin-bottom: var(--space-8);
    max-width: 700px;
    line-height: 1.6;
    text-align: center;
  }

  .hero-actions-container {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
  }

  .btn-large {
    padding: 1.2rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    border-radius: var(--radius-md);
  }

  .hero-content :global(.btn-arrow) {
    transition: transform var(--dur-fast) var(--ease-out-soft);
  }

  .btn-primary:hover :global(.btn-arrow) {
    transform: translateX(4px);
  }

  .aurora-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(140px);
    opacity: 0.35;
    z-index: 1;
    pointer-events: none;
    animation: floatSlow 25s infinite alternate ease-in-out;
  }

  .glow-1 {
    width: 550px;
    height: 550px;
    background: #d8b4fe;
    top: -150px;
    left: -100px;
  }

  .glow-2 {
    width: 600px;
    height: 600px;
    background: #f9a8d4;
    bottom: -200px;
    right: -100px;
    animation-delay: -5s;
  }

  .glow-3 {
    width: 500px;
    height: 500px;
    background: #fed7aa;
    top: 40%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.2;
    animation-delay: -10s;
  }

  @keyframes floatSlow {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(40px, 30px) scale(1.1); }
  }

  @media (max-width: 768px) {
    .hero-headline {
      font-size: var(--fs-3xl);
    }
    .hero-lead {
      font-size: var(--fs-base);
      margin-bottom: var(--space-6);
    }
    .btn-large {
      padding: 1rem 2rem;
      font-size: var(--fs-base);
    }
  }
</style>

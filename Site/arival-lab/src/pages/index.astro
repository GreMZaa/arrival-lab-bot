---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Programs from '../components/Programs.astro';
import Faq from '../components/Faq.astro';
import Agency from '../components/Agency.astro';
import AdminPanel from '../components/AdminPanel.astro';
import BuyApplyModals from '../components/BuyApplyModals.astro';
---

<Layout title="Oriva Lab — Лаборатория виртуальных аватаров и VTuber-моделей">
	<Header />
	<AdminPanel />
	<BuyApplyModals />
	
	<main>
		<Hero />
		<Stats />
		<Programs />
		<Agency />
		<Faq />
	</main>
	
	<footer class="footer">
		<div class="container footer-container">
			<div class="footer-brand">
				<a href="#" class="logo">
					<img src="/arrival_lab_logo.webp" alt="Oriva Lab" class="logo-img" width="32" height="32" loading="lazy" decoding="async" />
					<span class="logo-text">Oriva<span class="gradient-text">Lab</span></span>
				</a>
				<p class="brand-desc">Цифровая лаборатория виртуального стриминга. Запускаем VTuber-карьеры под ключ.</p>
			</div>
			
			<div class="footer-links-grid">
				<div class="footer-col">
					<h5 class="footer-title">Навигация</h5>
					<ul class="footer-links">
						<li><a href="#programs">Программы</a></li>
						<li><a href="#agency">Агентство</a></li>
						<li><a href="#faq">FAQ</a></li>
					</ul>
				</div>
				
				<div class="footer-col">
					<h5 class="footer-title">Документы</h5>
					<ul class="footer-links">
						<li><a href="/privacy">Конфиденциальность</a></li>
						<li><a href="/terms">Соглашение</a></li>
					</ul>
				</div>
				
				<div class="footer-col">
					<h5 class="footer-title">Контакты</h5>
					<ul class="footer-links">
						<li><a href="https://t.me/ArrivalLabBOT" target="_blank">Telegram Бот Oriva</a></li>
						<li><a href="https://t.me/success_vstream" target="_blank">Служба заботы</a></li>
					</ul>
				</div>
			</div>
		</div>
		
		<div class="footer-bottom">
			<div class="container footer-bottom-container">
				<p class="copyright">&copy; {new Date().getFullYear()} Oriva Lab. Все права защищены.</p>
			</div>
		</div>
	</footer>
</Layout>

<style>
	.logo {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		font-family: var(--font-display);
		font-size: var(--fs-xl);
		font-weight: 700;
		color: var(--color-text);
		margin-bottom: var(--space-3);
	}
	
	.logo-img {
		height: 32px;
		width: auto;
		border-radius: 50%;
	}
	
	.footer {
		background: var(--color-bg-alt);
		border-top: 1px solid var(--color-border);
		padding-block-start: var(--space-8);
	}
	
	.footer-container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-8);
		padding-block-end: var(--space-7);
	}
	
	.footer-brand {
		max-width: 360px;
	}
	
	.brand-desc {
		font-size: var(--fs-sm);
		color: var(--color-text-soft);
		line-height: 1.5;
	}
	
	.footer-links-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-4);
	}
	
	.footer-title {
		font-size: var(--fs-sm);
		font-weight: 600;
		color: var(--color-text);
		margin-bottom: var(--space-3);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	
	.footer-links {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}
	
	.footer-links a {
		font-size: var(--fs-sm);
		color: var(--color-text-soft);
		transition: color var(--dur-fast);
	}
	
	.footer-links a:hover {
		color: var(--color-primary);
	}
	
	.footer-bottom {
		border-top: 1px solid var(--color-border);
		padding-block: var(--space-4);
	}
	
	.footer-bottom-container {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-2);
	}
	
	.copyright, .design-by {
		font-size: var(--fs-xs);
		color: var(--color-text-muted);
	}
	
	@media (max-width: 768px) {
		.footer-container {
			grid-template-columns: 1fr;
			gap: var(--space-6);
		}
		
		.footer-bottom-container {
			flex-direction: column;
			text-align: center;
		}
	}
</style>
